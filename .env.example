# Google Gemini API (free tier)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Sheets API (free tier)
# 1. Google Cloud Console → APIs → Sheets API 활성화
# 2. Credentials → API Key 생성
# 3. Google Sheets URL에서 ID 추출: https://docs.google.com/spreadsheets/d/{THIS_IS_THE_ID}/edit
GOOGLE_SHEETS_ID=
GOOGLE_API_KEY=
